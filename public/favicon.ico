<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#7c6aff"/>
      <stop offset="100%" style="stop-color:#4f3ff0"/>
    </linearGradient>
    <linearGradient id="bolt" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ffe066"/>
      <stop offset="100%" style="stop-color:#ffb300"/>
    </linearGradient>
  </defs>

  <!-- 圓角背景 -->
  <rect width="64" height="64" rx="14" fill="url(#bg)"/>

  <!-- 票券主體 -->
  <rect x="8" y="20" width="48" height="24" rx="4" fill="white" fill-opacity="0.15"/>

  <!-- 票券左切口 -->
  <circle cx="8" cy="32" r="5" fill="#0f1117"/>
  <!-- 票券右切口 -->
  <circle cx="56" cy="32" r="5" fill="#0f1117"/>

  <!-- 虛線分隔 -->
  <line x1="13" y1="32" x2="51" y2="32" stroke="white" stroke-width="1.5" stroke-dasharray="3,3" stroke-opacity="0.4"/>

  <!-- 閃電 -->
  <polygon points="35,16 27,33 32,33 29,48 37,31 32,31" fill="url(#bolt)"/>
</svg>
